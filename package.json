{
	"name": "axxa-os-ai-agent",
	"version": "0.1.235",
	"description": "AXXA OS — AI Agent (Obsidian plugin).",
	"private": true,
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "vitest --project unit run",
		"test:watch": "vitest --project unit",
		"test:stories": "vitest --project storybook run",
		"test:all": "vitest run",
		"size": "node scripts/size-report.mjs",
		"collect:hot": "node scripts/collect-hot.mjs",
		"deploy:output": "node scripts/deploy.mjs",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"dependencies": {
		"preact": "^10.29.2",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"zustand": "^4.5.5"
	},
	"devDependencies": {
		"@codemirror/autocomplete": "^6.20.3",
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.43.0",
		"@storybook/addon-a11y": "^10.4.6",
		"@storybook/addon-docs": "^10.4.6",
		"@storybook/addon-links": "^10.4.6",
		"@storybook/addon-themes": "^10.4.6",
		"@storybook/addon-vitest": "^10.4.6",
		"@storybook/react": "^10.4.6",
		"@storybook/react-vite": "^10.4.6",
		"@types/node": "^16.18.108",
		"@types/react": "^18.3.11",
		"@types/react-dom": "^18.3.0",
		"@vitejs/plugin-react": "^4.7.0",
		"@vitest/browser": "^4.1.9",
		"@vitest/browser-playwright": "^4.1.9",
		"builtin-modules": "^3.3.0",
		"esbuild": "^0.20.2",
		"lucide": "^0.460.0",
		"obsidian": "latest",
		"playwright": "^1.61.1",
		"storybook": "^10.4.6",
		"tslib": "^2.7.0",
		"typescript": "^5.6.2",
		"vite": "^5.4.21",
		"vitest": "^4.1.9"
	}
}
